    {
      "parameters": {
        "jsCode": "// Extrae el numero de Orden de Servicio del asunto del mail (ej: OS0001, OS-0001)\nconst item = $input.item;\n\n// Gmail puede devolver el asunto en distintos lugares segun el formato\nlet subject =\n  item.json.subject \n  item.json.Subject \n  item.json.headers?.subject \n  item.json.headers?.Subject \n  '';\n\n// Si sigue vacio, buscar en el array de headers del formato raw de Gmail\nif (!subject && item.json.payload?.headers) {\n  const headerSubject = item.json.payload.headers.find(h => h.name === 'Subject');\n  if (headerSubject) subject = headerSubject.value;\n}\n\nconst match = subject.match(/OS[_-]?\\d+/i);\nitem.json.ordenExtraida = match ? match[0].toUpperCase().replace('-', '_') : null;\nitem.json.asuntoDebug = subject; // para poder ver que asunto detecto, sacalo despues\nreturn item;\n"
      },
