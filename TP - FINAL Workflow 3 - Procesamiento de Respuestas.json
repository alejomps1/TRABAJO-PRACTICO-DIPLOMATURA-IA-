      "parameters": {
        "jsCode": "// Extrae y valida la clasificacion devuelta por Gemini\nconst item = $input.item;\nconst raw = item.json?.candidates?.[0]?.content?.parts?.[0]?.text || '';\nconst clasificacion = raw.trim().toUpperCase();\nconst validas = ['APROBADO', 'RECHAZADO', 'CONSULTA', 'INDETERMINADO'];\nitem.json.clasificacion = validas.includes(clasificacion) ? clasificacion : 'INDETERMINADO';\nreturn item;"
      },
